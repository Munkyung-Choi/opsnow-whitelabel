# =============================================================================
# docs/exec-plans/rls-fixtures.env.example
# RLS 검증 테스트 픽스처 설정 템플릿
# =============================================================================
# 사용법:
#   cp docs/exec-plans/rls-fixtures.env.example docs/exec-plans/rls-fixtures.env
#   → rls-fixtures.env 에 실제 값을 채운 뒤 npm run check:rls 실행
#
# 주의: rls-fixtures.env 는 .gitignore 에 포함됨 (민감 정보 포함)
# =============================================================================

# =============================================================================
# Supabase 연결 정보 (이미 .env.local에 있으면 생략 가능)
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL 과 NEXT_PUBLIC_SUPABASE_ANON_KEY 는
# .env.local 에서 자동으로 로드됩니다 (별도 설정 불필요)

# =============================================================================
# 테스트 픽스처 UUID
# Supabase Dashboard → Table Editor 에서 확인
# =============================================================================

# 파트너 A (자기 데이터 접근 + 크로스테넌트 격리 기준)
RLS_TEST_PARTNER_A_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# auth.users 에 등록된 파트너 A admin 계정 이메일 + 비밀번호
RLS_TEST_PARTNER_A_ADMIN_EMAIL=partner-a-admin@example.com
RLS_TEST_PARTNER_A_ADMIN_PASSWORD=your-test-password

# 파트너 B (크로스테넌트 차단 검증용 — T-01, T-02)
RLS_TEST_PARTNER_B_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RLS_TEST_PARTNER_B_ADMIN_EMAIL=partner-b-admin@example.com
RLS_TEST_PARTNER_B_ADMIN_PASSWORD=your-test-password

# Master Admin 계정 (T-03 검증용)
RLS_TEST_MASTER_ADMIN_EMAIL=master-admin@example.com
RLS_TEST_MASTER_ADMIN_PASSWORD=your-test-password
