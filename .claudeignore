# .claudeignore - Claude Code 토큰 절감 및 보안을 위한 무시 규칙
# 작성일: 2026-04-08

# 빌드 산출물 및 캐시
.git
.next
node_modules
dist
build
*.tsbuildinfo

# 패키지 잠금 파일 (의존성 목록은 package.json으로 충분)
package-lock.json

# 로그
*.log

# 이미지/바이너리 (읽어도 의미 없는 파일)
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.woff
*.woff2

# OS 메타파일
.DS_Store

# Supabase CLI 임시 파일
supabase/.branches
supabase/.temp

# 보안: 환경 변수 파일(API Key 등 포함) 분석 제외
# ⚠️ .env.example은 민감정보가 없으므로 예외 처리 (Claude가 환경변수 목록 파악에 활용)
.env
.env.local
.env.development
.env.production
.env.test