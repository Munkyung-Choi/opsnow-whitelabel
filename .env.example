# =============================================================================
# .env.example — 환경변수 명세 (WL-48)
# 용도: 신규 개발자(또는 AI)가 로컬 환경 구성 시 참조하는 키 이름 + 설명 목록
# ⚠️  이 파일에는 실제 값(Secret)을 절대 입력하지 않는다.
# ⚠️  실제 값은 .env.local에 입력하고 .gitignore로 커밋에서 제외한다.
# =============================================================================


# -----------------------------------------------------------------------------
# [Supabase] 프로젝트 연결 (필수)
# -----------------------------------------------------------------------------

# Supabase 프로젝트 URL (대시보드 > Settings > API > Project URL)
# 노출 범위: 클라이언트 번들에 포함됨 (NEXT_PUBLIC_) — 공개 가능
NEXT_PUBLIC_SUPABASE_URL= # @required

# Supabase anon 공개 키 (대시보드 > Settings > API > anon public)
# 노출 범위: 클라이언트 번들에 포함됨 (NEXT_PUBLIC_) — 공개 가능 (RLS로 보호)
NEXT_PUBLIC_SUPABASE_ANON_KEY= # @required

# Supabase service_role 비밀 키 (대시보드 > Settings > API > service_role)
# 노출 범위: 서버사이드 전용 (Route Handler, Server Action)
# ⚠️  절대 클라이언트 컴포넌트에 노출 금지. 모든 RLS를 우회함.
SUPABASE_SERVICE_ROLE_KEY= # @required

# Supabase 프로젝트 ID (대시보드 URL의 subdomain 또는 Settings > General)
# 용도: `npx supabase gen types typescript --project-id <ID>` 타입 생성 시 사용
# 노출 범위: 서버사이드 전용
SUPABASE_PROJECT_ID=

# Supabase 직접 DB 연결 URL (PostgreSQL connection string)
# 용도: RLS 검증 스크립트(docs/exec-plans/), 마이그레이션 디버깅 시 사용
# 형식: postgresql://postgres.<project-id>:<password>@<host>:5432/postgres
# ⚠️  DB 비밀번호 포함 — 절대 커밋 금지
SUPABASE_DB_URL=


# -----------------------------------------------------------------------------
# [Site] 사이트 URL
# -----------------------------------------------------------------------------

# 배포된 사이트의 기본 URL (Vercel 배포 URL 또는 커스텀 도메인)
# 용도: OG Tag, 절대 URL 생성, 이메일 링크 등
NEXT_PUBLIC_SITE_URL=


# -----------------------------------------------------------------------------
# [Local Development] 로컬 개발 환경 전용
# -----------------------------------------------------------------------------

# 로컬에서 http://localhost:3000 접근 시 기본으로 사용할 파트너 슬러그
# 용도: proxy.ts에서 서브도메인 미감지 시 이 값으로 파트너 컨텍스트 주입
# 형식: Supabase partners.subdomain 컬럼 값 (예: partner-a)
# 노출 범위: 서버사이드 전용 (NEXT_PUBLIC_ 접두사 없음 — 클라이언트 번들 미포함)
# 참고: CLAUDE.md §10.3 CI/CD 환경 Fallback
DEV_PARTNER_SLUG=


# -----------------------------------------------------------------------------
# [External APIs] 외부 서비스 연동
# -----------------------------------------------------------------------------

# Google Gemini API 키 (AI 감사·교차검증 시 사용)
# 용도: Eval-Harness 기반 AI 독립 검증 (WL-36, WL-39)
# 노출 범위: 서버사이드 전용
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# [Email] Resend API
# -----------------------------------------------------------------------------

# Resend API 키 (이메일 발송 서비스)
# 용도: ContactForm 리드 알림 이메일, 파트너 온보딩 알림
# 노출 범위: 서버사이드 전용
RESEND_API_KEY= # @required


# -----------------------------------------------------------------------------
# [Admin Impersonation] 대리 접속 쿠키 서명 (WL-51)
# -----------------------------------------------------------------------------

# HMAC-SHA256 서명 비밀. 32 bytes 이상 랜덤.
# 생성: `openssl rand -base64 32`
# 용도: opsnow_impersonate 쿠키 서명·검증
# 노출 범위: 서버사이드 전용 (Route Handler)
# ⚠️  유출 시 master_admin 세션과 결합하여 임의 partner_id 쿠키 위조 가능 — 즉시 로테이션
IMPERSONATION_SIGNING_SECRET= # @required


# -----------------------------------------------------------------------------
# [Rate Limiting] Upstash Redis — 파트너별 Noisy Neighbor 방어 (WL-145)
# -----------------------------------------------------------------------------

# Upstash Redis REST URL (대시보드 > Database > REST API > UPSTASH_REDIS_REST_URL)
# 용도: src/lib/rate-limit.ts → @upstash/ratelimit 엔드포인트
# 노출 범위: 서버사이드 전용 (Edge Runtime proxy.ts)
# 무료 티어: 10,000 commands/day — analytics: false로 analytics 명령 차단 필요
UPSTASH_REDIS_REST_URL= # @required

# Upstash Redis REST Token (대시보드 > Database > REST API > UPSTASH_REDIS_REST_TOKEN)
# 용도: REST API 호출 인증 토큰
# 노출 범위: 서버사이드 전용
# ⚠️  유출 시 파트너 rate limit 우회 및 Redis 데이터 조작 가능 — 즉시 로테이션
UPSTASH_REDIS_REST_TOKEN= # @required

# Rate Limit 요청 수 (선택) — 기본: dev/test 500, production 50
# 용도: 파트너별 sliding window 내 허용 요청 수 override
RATE_LIMIT_REQUESTS=

# Rate Limit 시간 윈도우 (선택) — 기본: '60 s'
# 형식: "<숫자> s" (초 단위) — 예: "60 s", "10 s", "300 s"
RATE_LIMIT_WINDOW=
